  "keyFeatures": [
    "In-browser Monaco Editor with syntax highlighting and autocomplete (Java, Python, C++, Bash)",
    "Server-side dynamic compilation and execution without restarting the application",
    "Real-time output streaming via WebSocket (STOMP over SockJS)",
    "Multi-file project support with a single entry-point model",
    "SSH-based deployment to remote servers (source code, compiled code, or pre-built executables)",
    "Remote instance management with command execution and preset command groups",
    "File upload for pre-compiled binaries and remote executables",
    "Built-in terminal panel for live stdout/stderr output"
  ],
  "publicApiSurface": [
